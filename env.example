# 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# OpenAI API Key（可选，用于 AI 功能）
# 如果你想使用 AI 辅助编写简历功能，需要设置这个
OPENAI_API_KEY=your_openai_api_key_here

# Google Fonts API Key（可选）
# 如果你想使用 Google Fonts 字体选择功能，需要设置这个
# 获取方式：https://developers.google.com/fonts/docs/developer_api#APIKey
NUXT_PUBLIC_GOOGLE_FONTS_KEY=your_google_fonts_api_key_here

# 站点 URL 配置
# 生产环境中设置为你的实际域名
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# 应用基础路径
# 如果部署在子路径下，需要设置这个，例如：/resume/
NUXT_APP_BASE_URL=/

# 端口/主机配置（dev/容器）
# devServer 使用 HOST/PORT，容器对外暴露 WEB_PORT
PORT=3000
HOST=0.0.0.0
WEB_PORT=3000

# Vite HMR 透过反向代理时的外部地址（仅开发模式）
# 例如通过 101.201.60.17 访问时：
# NUXT_VITE_HMR_HOST=101.201.60.17
# NUXT_VITE_HMR_PORT=80
# 协议缺省为 ws；如需 wss，可显式设置。
NUXT_VITE_HMR_HOST=
NUXT_VITE_HMR_PORT=
NUXT_VITE_HMR_PROTOCOL=
NUXT_VITE_HMR_PATH=
# 设置为 true 时，强制 HMR WebSocket 在浏览器端根据当前访问主机/端口动态拼接，
# 适用于需要同时通过代理域名和本机 IP 访问的场景。
NUXT_VITE_HMR_DYNAMIC=false

# 对外可访问的完整站点 URL（用于站点地图、PWA 等）
# 生产部署时设置为你的域名，例如：https://resume.example.com
PUBLIC_URL=http://localhost:3000

# Node.js 环境
NODE_ENV=production

# Chatbot：对话模式严格禁止编辑（默认 true，设置为 'false' 可关闭）
NUXT_PUBLIC_CHATBOT_STRICT_ASK_NO_EDIT=true

# FastAPI 后端基址（设置后前端将直连 FastAPI，而不是 Node 代理）
FASTAPI_BASE_URL=http://127.0.0.1:8000

# 启用 Agents 模式（FastAPI /api/ai 使用 Agents SDK Sessions）
USE_AGENTS=true

# --- Agent backend -> Nuxt state bridge ---
# Base URL of the Nuxt dev/preview server for reading editor state.
# FastAPI agent endpoint calls `${NUXT_BASE_URL}/api/editor-state`.
NUXT_BASE_URL=http://127.0.0.1:3000
# Optional token for protected Nuxt endpoints; if set, backend sends header `x-mcp-token`.
MCP_QUEUE_TOKEN=

# --- Backend timeouts (optional) ---
# Increase if /api/rec/create or /api/ai time out on slow networks/models.
# Total read timeout (seconds) for OpenAI Responses API requests.
OPENAI_RESPONSES_TIMEOUT=180
# Specific override for recommendation creation endpoint.
REC_CREATE_TIMEOUT=180
# Optional override for Responses API base URL (e.g., self-hosted proxy)
# OPENAI_RESPONSES_URL=https://api.openai.com/v1/responses

# Agent output length cap (backend)
AGENT_MAX_OUTPUT_TOKENS=2048

# Optional: specify Agent IDs for document creation endpoints (FastAPI /api/create)
# If set, backend will call the Responses API using the Agent instead of raw prompts.
CV_AGENT_ID=
PS_AGENT_ID=
REC_AGENT_ID=

# Optional: override the Prompt resource used for CV generation (default already set)
CV_PROMPT_ID=pmpt_68d9f3fe3eb48197abd642d6984d6d3e01709ceef551872c
CV_PROMPT_VERSION=

# Optional: override the Prompt resource used for recommendation-agent creation
REC_PROMPT_ID=pmpt_68c1963af49081948e0b1a7d51152a530b1e5a4c68ba8796
REC_PROMPT_VERSION=4
